# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (Project Settings -> API) ---
# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Used by /api routes to read
# across both partners (bypasses RLS) for task generation and reveal.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Claude (https://console.anthropic.com/) ---
# Server-only. Used only inside /api routes.
ANTHROPIC_API_KEY=sk-ant-...

# --- Evening reminder email (optional) ---
# Brevo transactional email, reused from the Supabase auth setup. Without
# these the reminder cron is a harmless no-op.
BREVO_API_KEY=xkeysib-...
BREVO_SENDER=Hidden Agenda <hello@yourdomain.com>

# Shared secret guarding /api/cron/remind. Vercel Cron sends it automatically
# as "Authorization: Bearer <CRON_SECRET>" when set in project env.
CRON_SECRET=generate-a-long-random-string
