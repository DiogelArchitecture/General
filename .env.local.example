# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (Project Settings -> API) ---
# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Used by /api routes to read
# across both partners (bypasses RLS) for task generation and reveal.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Claude (https://console.anthropic.com/) ---
# Server-only. Used only inside /api routes.
ANTHROPIC_API_KEY=sk-ant-...
